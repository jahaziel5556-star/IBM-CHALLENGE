MATCHMIND_ENV=development

BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_API_BASE_URL=http://127.0.0.1:8000

DATABASE_URL=sqlite:///./matchmind_one.db
DATABASE_AUTO_INIT=true
DATABASE_ECHO=false
SEED_DEMO_DATA=true
UPLOAD_DIR=uploads
VIDEO_ANALYSIS_SAMPLE_SECONDS=4
VIDEO_ANALYSIS_MAX_SAMPLES=60
VIDEO_ANALYSIS_MIN_EVENTS=3
VIDEO_ANALYSIS_USE_GRANITE=true

# Example PostgreSQL URL for Docker or a managed database:
# DATABASE_URL=postgresql+psycopg://matchmind:matchmind@localhost:5432/matchmind_one

IBM_WATSONX_API_KEY=
IBM_WATSONX_PROJECT_ID=
IBM_WATSONX_URL=https://us-south.ml.cloud.ibm.com
IBM_WATSONX_MODEL_ID=ibm/granite-3-8b-instruct
IBM_WATSONX_API_VERSION=2025-10-25
IBM_WATSONX_TIMEOUT_SECONDS=30
IBM_WATSONX_USE_MOCK=true

LANGFLOW_BASE_URL=
DOCLING_SOURCE_DIR=./assets/knowledge
CONTEXT_FORGE_BASE_URL=
